{
  "mcpServers": {
    "dart": {
      "command": "dart",
      "args": [
        "mcp-server"
      ]
    },
    "very good cli": {
      "command": "very_good",
      "args": [
        "mcp"
      ]
    },
    "Railway": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@railway/mcp-server"
      ],
      "env": {}
    },
    "ios-simulator": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "ios-simulator-mcp"
      ],
      "env": {}
    }
  }
}